# Supabase — obtenha em https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://seu-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_publishable_ou_anon_key

# Apenas no servidor. Nunca exponha no cliente.
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
SIMULAMEI_API_KEY_SECRET=troque-por-um-secret-longo-e-aleatorio-para-hmac-das-api-keys
SIMULAMEI_API_KEY=smei_sua_chave_para_chamadas_internas

# Admin
ADMIN_EMAIL=admin@simulamei.com.br
ADMIN_EMAILS=admin@simulamei.com.br,financeiro@simulamei.com.br

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_sua_chave_publica
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# AI
ANTHROPIC_API_KEY=sk-ant-sua-chave
ANTHROPIC_MODEL=claude-haiku-4-5

# Billing
STRIPE_SECRET_KEY=sk_test_sua_chave
STRIPE_WEBHOOK_SECRET=whsec_sua_chave
STRIPE_PRICE_REPORT_ID=price_relatorio
STRIPE_PRICE_MONITOR_ID=price_monitor
STRIPE_PRICE_ACCOUNTANT_STARTER_ID=price_accountant_starter
STRIPE_PRICE_ACCOUNTANT_PRO_ID=price_accountant_pro

# Transactional email
RESEND_API_KEY=re_sua_chave
RESEND_FROM_EMAIL=SimulaMEI <no-reply@simulamei.com.br>
ACCOUNTANT_LEAD_NOTIFY_EMAIL=comercial@simulamei.com.br

# Cron / background
CRON_SECRET=troque-por-um-secret-longo-para-rotas-de-cron
